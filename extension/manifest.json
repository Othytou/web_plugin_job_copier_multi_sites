{
	"manifest_version": 3,
	"name": "Job Copier Multi-Sites",
	"version": "1.2.1",
	"description": "Copie rapidement le contenu des offres d'emploi depuis Indeed, LinkedIn, Welcome to the Jungle, HelloWork et Free-Work",
	"permissions": [
		"storage",
		"activeTab",
		"clipboardWrite",
		"scripting"
	],
	"host_permissions": [
		"*://*.indeed.com/*",
		"*://*.linkedin.com/*",
		"*://*.welcometothejungle.com/*",
		"*://*.hellowork.com/*",
		"*://*.free-work.com/*"
	],
	"commands": {
		"copy-job": {
			"suggested_key": {
				"default": "Ctrl+Shift+M"
			},
			"description": "Copier le contenu de l'offre d'emploi"
		}
	},
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": [
				"*://*.indeed.com/*",
				"*://*.linkedin.com/*",
				"*://*.welcometothejungle.com/*",
				"*://*.hellowork.com/*",
				"*://*.free-work.com/*"
			],
			"js": [
				"content.js"
			],
			"run_at": "document_idle"
		}
	],
	"action": {
		"default_title": "Job Copier Multi-Sites",
		"default_popup": "popup.html"
	},
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	}
}